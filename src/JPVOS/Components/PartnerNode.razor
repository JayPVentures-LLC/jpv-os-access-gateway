<span class="@NodeClass" style="left:@X%; top:@Y%;">
    <span class="partner-node-dot"></span>
    <span class="partner-node-label">@Name</span>
</span>

@code {
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public int X { get; set; }
    [Parameter] public int Y { get; set; }
    [Parameter] public bool IsCore { get; set; }

    private string NodeClass => IsCore ? "partner-node partner-node-core" : "partner-node";
}
