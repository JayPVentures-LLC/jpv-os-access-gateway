<section class="brand-page jpv-section">
    <div class="brand-layout">
        <div class="brand-copy">
            <div class="jpv-kicker">@Kicker</div>
            <h1 class="jpv-title">@Title</h1>
            <p class="jpv-lede">@Lead</p>

            <div class="brand-capabilities">
                @foreach (var item in Capabilities.Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                {
                    var parts = item.Split("::", 2, StringSplitOptions.TrimEntries);
                    <div class="brand-capability">
                        <span>@(parts.Length > 0 ? parts[0] : item)</span>
                        <p>@(parts.Length > 1 ? parts[1] : "")</p>
                    </div>
                }
            </div>
        </div>

        <div class="brand-media">
            <img src="@Image" alt="@Title image" />
        </div>
    </div>

    <section class="pricing-section">
        <div class="partner-section-label">Packages & Checkout</div>
        <div class="package-grid">
            @ChildContent
        </div>
    </section>
</section>

@code {
    [Parameter] public string Kicker { get; set; } = "";
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Lead { get; set; } = "";
    [Parameter] public string Image { get; set; } = "";
    [Parameter] public string Capabilities { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
