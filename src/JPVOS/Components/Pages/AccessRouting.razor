@page "/access"
@page "/access-routing"

<div class="page-stack">
    <PageHero Kicker="Access"
              Title="Login and environment routing."
              Description="init routes people into the right access environment: member access, partner portal, enterprise console, admin operations, developer hub, and support center."
              Image="@AssetPaths.JpvOs.Core"
              ImageAlt="JPV-OS access routing core visual" />

    <section class="content-section">
        <div class="access-grid">
            <AccessCard Environment="Member" Title="Member Access" Description="Community entry, updates, selected resources, and guided ecosystem movement." Href="/pricing" />
            <AccessCard Environment="Partner" Title="Partner Portal" Description="Technology ecosystem intake, collaboration review, and partner routing." Href="/partners" />
            <AccessCard Environment="Enterprise" Title="Enterprise Console" Description="Architecture, governance, identity, security, deployment, and operations requests." Href="/jaypventures-llc" />
            <AccessCard Environment="Admin" Title="Admin Operations" Description="Internal review pathway for governance, security posture, deployment, and delivery decisions." Href="/checkout-not-configured" />
            <AccessCard Environment="Developer" Title="Developer Hub" Description="Development workflow, repositories, automation, runtime tooling, and implementation routing." Href="/ecosystem" />
            <AccessCard Environment="Support" Title="Support Center" Description="Support routing for account, package, access, partner, and implementation questions." Href="/contact" />
        </div>
    </section>

    <CTASection Title="Get init access."
                Description="Start with the path that matches who you are and what you need to do next."
                PrimaryCta="Get init"
                PrimaryHref="/pricing"
                SecondaryCta="Explore Ecosystem"
                SecondaryHref="/ecosystem" />
</div>
