@page "/ventures"

<div class="page-stack">
    <section class="content-section">
        <SectionHeader Kicker="Ventures"
                       Title="Venture pathways for launches, products, and ecosystem growth."
                       Description="init organizes the venture side of the ecosystem into pathways for public launches, digital products, creator systems, enterprise opportunities, and long-range growth." />
        <div class="grid-3">
            <GlassCard Eyebrow="Launches" Title="Launch pathways" Description="Plan the offer, public surface, audience route, and access path before a venture goes live." />
            <GlassCard Eyebrow="Products" Title="Digital products" Description="Shape products, memberships, resources, and checkout-ready packages around clear user entry points." />
            <GlassCard Eyebrow="Creators" Title="Creator systems" Description="Connect content, community, launches, memberships, and product development for creator-led ventures." />
            <GlassCard Eyebrow="Enterprise" Title="Enterprise opportunities" Description="Route infrastructure, governance, identity, security, deployment, and operations opportunities into JayPVentures LLC." />
            <GlassCard Eyebrow="Growth" Title="Ecosystem growth" Description="Use the application surface to keep ventures connected to access, partners, pricing, and delivery." />
            <GlassCard Eyebrow="Pipeline" Title="Future launches" Description="Keep experiments, offers, and implementation paths organized around real pathways and package readiness." />
        </div>
    </section>

    <section class="content-section">
        <SectionHeader Kicker="Venture Routes"
                       Title="Choose the path that matches the work."
                       Description="We route creator, enterprise, partner, and custom implementation work through dedicated surfaces so the ecosystem stays legible." />
        <div class="grid-3">
            <RouteTile Href="/jaypventures" Eyebrow="Creator" Title="jaypventures" Description="Community, launches, memberships, digital products, and creator access." />
            <RouteTile Href="/jaypventures-llc" Eyebrow="Enterprise" Title="JayPVentures LLC" Description="Architecture, governance, identity, security, deployment, and operations." />
            <RouteTile Href="/pricing" Eyebrow="Packages" Title="Pricing" Description="Checkout-ready package paths for the next step." />
        </div>
    </section>
</div>
