@page "/admin"

<div class="page-stack">
    <PageHero Kicker="Admin"
              Title="Operational review surface."
              Description="Administrative routing and operational review interfaces are being finalized for governed access workflows."
              Image="@AssetPaths.JpvOs.Brand"
              ImageAlt="JPV-OS administrative routing interface" />

    <section class="content-section">
        <SectionHeader Kicker="Status"
                       Title="Governed access only."
                       Description="This surface is reserved for protected operations, governance review, incident routing, and infrastructure authority workflows." />

        <div class="feature-grid">
            <article class="glass-card">
                <h3>Governance Review</h3>
                <p>Structured review paths for protected operational decisions.</p>
            </article>

            <article class="glass-card">
                <h3>Incident Routing</h3>
                <p>Escalation pathways for security, access, and infrastructure events.</p>
            </article>

            <article class="glass-card">
                <h3>Operational Integrity</h3>
                <p>Administrative workflows remain aligned with JPV-OS governance standards.</p>
            </article>
        </div>
    </section>
</div>