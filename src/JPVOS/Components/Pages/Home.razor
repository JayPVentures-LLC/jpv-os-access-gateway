@page "/"
@page "/init"

<main class="canva-parity-page">

    <section class="cp-hero" aria-labelledby="cp-hero-title">
        <div class="cp-bg-grid"></div>
        <div class="cp-bg-orb cp-orb-a"></div>
        <div class="cp-bg-orb cp-orb-b"></div>

        <div class="cp-shell">

            <p class="cp-eyebrow">JPV-OS • INFRASTRUCTURE ACCESS SYSTEM</p>

            <h1 id="cp-hero-title" class="cp-title">Welcome to the Venture.</h1>

            <p class="cp-lead">
                Enterprise-grade operating infrastructure for creators, partners,
                access routing, payments, Discord provisioning, and ecosystem execution.
            </p>

            <div class="cp-actions" aria-label="Primary access actions">
                <a class="cp-btn cp-btn-primary" href="/pricing">Get init</a>
                <a class="cp-btn cp-btn-secondary" href="/access">Explore Access</a>
            </div>

            <div class="cp-metric-strip" aria-label="Ecosystem status metrics">
                <article class="cp-metric">
                    <span>UPTIME</span>
                    <strong>99.99%</strong>
                </article>

                <article class="cp-metric">
                    <span>ACCESS LANES</span>
                    <strong>06</strong>
                </article>

                <article class="cp-metric">
                    <span>CHECKOUT</span>
                    <strong>Stripe</strong>
                </article>

                <article class="cp-metric">
                    <span>COMMUNITY</span>
                    <strong>Discord</strong>
                </article>
            </div>

        </div>
    </section>

    <section class="cp-section cp-routing" aria-labelledby="cp-routing-title">
        <div class="cp-section-head">
            <p class="cp-eyebrow cp-eyebrow-pink">ECOSYSTEM ARCHITECTURE</p>
            <h2 id="cp-routing-title">Operational Routing Layers</h2>
            <p>
                Six access paths structured around what users need to do next:
                join, build, operate, partner, scale, or request custom deployment.
            </p>
        </div>

        <div class="cp-card-grid">
            <article class="cp-card">
                <span>01</span>
                <h3>Member Access</h3>
                <p>Community entry, updates, resources, and Discord-based member routing.</p>
            </article>

            <article class="cp-card">
                <span>02</span>
                <h3>VIP Venture</h3>
                <p>Priority access, venture visibility, and expanded ecosystem channels.</p>
            </article>

            <article class="cp-card">
                <span>03</span>
                <h3>Creator Lane</h3>
                <p>Creator launch systems, monetization support, and content infrastructure.</p>
            </article>

            <article class="cp-card">
                <span>04</span>
                <h3>Operator</h3>
                <p>Operational workflows, implementation visibility, and advanced execution paths.</p>
            </article>

            <article class="cp-card">
                <span>05</span>
                <h3>Enterprise</h3>
                <p>Infrastructure coordination, partner execution, and private implementation review.</p>
            </article>

            <article class="cp-card">
                <span>06</span>
                <h3>Sovereign</h3>
                <p>Custom ecosystem architecture, governance alignment, and strategic deployment planning.</p>
            </article>
        </div>
    </section>

    <section class="cp-section cp-pricing-preview" aria-labelledby="cp-pricing-title">
        <div class="cp-section-head">
            <p class="cp-eyebrow">ACCESS PACKAGES</p>
            <h2 id="cp-pricing-title">Structured access. Clear routing.</h2>
            <p>
                Payments route through Stripe. Member and VIP Venture access route through Discord.
                Enterprise and Sovereign requests move through direct intake.
            </p>
        </div>

        <div class="cp-price-row">
            <article class="cp-price"><span>Member</span><strong>$10/mo</strong></article>
            <article class="cp-price"><span>VIP Venture</span><strong>$30/mo</strong></article>
            <article class="cp-price"><span>Creator Lane</span><strong>$80/mo</strong></article>
            <article class="cp-price"><span>Operator</span><strong>$250/mo</strong></article>
            <article class="cp-price"><span>Enterprise</span><strong>$900/mo</strong></article>
            <article class="cp-price"><span>Sovereign</span><strong>Custom</strong></article>
        </div>
    </section>

    <section class="cp-final">
        <p class="cp-eyebrow">READY FOR ACCESS</p>
        <h2>Get init.</h2>
        <p>
            Start with the correct access lane, route payments through Stripe,
            connect Discord where needed, and move through the JPV ecosystem with operational clarity.
        </p>
        <a class="cp-btn cp-btn-primary" href="/pricing">View Access Packages</a>
    </section>

</main>
