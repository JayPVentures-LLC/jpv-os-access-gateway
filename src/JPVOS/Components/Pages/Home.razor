@page "/"
@layout HomeLayout

@* init / JPV-OS Access Gateway Homepage — Clean Rebuild *@

<div class="init-home">
  <!-- Cinematic Atmospheric Background -->
  <div class="atmospheric-bg"></div>

  <!-- Sticky Glass Navigation (Consolidated) -->
  <nav class="init-nav glass-nav" aria-label="Main Navigation">
    <div class="nav-content">
      <a class="nav-logo" href="/">init</a>
      <div class="nav-links">
        <a href="/" class="nav-link active">Home</a>
        <a href="/ecosystem" class="nav-link">Ecosystem</a>
        <a href="/access" class="nav-link">Access</a>
        <a href="/docs" class="nav-link">Docs</a>
      </div>
      <a href="/access" class="nav-cta">Get init</a>
    </div>
    <div class="nav-status-strip" aria-live="polite">
      <span class="status-dot online"></span>
      <span class="status-label">All systems operational</span>
    </div>
  </nav>

  <!-- Hero Section (Cinematic, Tightened) -->
  <section class="hero">
    <div class="hero-left glass-panel">
      <div class="hero-eyebrow">init &bull; powered by JPV-OS &bull; operated by JayPVentures LLC</div>
      <h1 class="hero-title">Welcome to the Venture</h1>
      <div class="hero-subtitle">
        Connected infrastructure, creator ecosystems, enterprise access, and scalable operational architecture unified
        through a single intelligent platform.
      </div>
      <div class="hero-ctas">
        <a href="/access" class="cta-primary">Enter the Ecosystem</a>
        <a href="/ecosystem" class="cta-secondary">Explore Architecture</a>
      </div>
      <div class="metrics">
        <div class="metric-card pulse"><span>Uptime</span><strong>99.99%</strong></div>
        <div class="metric-card pulse"><span>Active Nodes</span><strong>14,200</strong></div>
        <div class="metric-card pulse"><span>Operations</span><strong>847</strong></div>
        <div class="metric-card pulse"><span>Regions</span><strong>52</strong></div>
      </div>
    </div>
    <div class="hero-right">
      <div class="ecosystem-visual animated-ecosystem" aria-label="Animated Ecosystem Visualization">
        <!-- Cinematic SVG ecosystem visualization with telemetry, routing, orbital motion -->
        <svg viewBox="0 0 320 320" width="90%" height="320" fill="none" xmlns="http://www.w3.org/2000/svg"
             class="ecosystem-svg">
          <defs>
            <radialGradient id="ecoGlow" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#4e7fff" stop-opacity="0.35" />
              <stop offset="100%" stop-color="#4e7fff" stop-opacity="0" />
            </radialGradient>
            <filter id="ecoBlur" x="-20%" y="-20%" width="140%" height="140%">
              <feGaussianBlur stdDeviation="8" />
            </filter>
          </defs>
          <!-- Orbital paths -->
          <ellipse cx="160" cy="160" rx="110" ry="54" stroke="#7f9fff55" stroke-width="2" fill="none"
                   stroke-dasharray="8 8" />
          <ellipse cx="160" cy="160" rx="80" ry="110" stroke="#4e7fff33" stroke-width="2" fill="none"
                   stroke-dasharray="12 12" />
          <!-- Main node -->
          <circle class="eco-node main" cx="160" cy="160" r="54" />
          <!-- Layered nodes -->
          <circle class="eco-node" cx="60" cy="80" r="18" />
          <circle class="eco-node" cx="260" cy="80" r="18" />
          <circle class="eco-node" cx="60" cy="240" r="18" />
          <circle class="eco-node" cx="260" cy="240" r="18" />
          <!-- Telemetry/routing pulses -->
          <circle cx="160" cy="106" r="6" fill="#7f9fff" opacity="0.7">
            <animate attributeName="r" values="6;12;6" dur="2.5s" repeatCount="indefinite" />
            <animate attributeName="opacity" values="0.7;0.2;0.7" dur="2.5s" repeatCount="indefinite" />
          </circle>
          <circle cx="160" cy="214" r="6" fill="#7f9fff" opacity="0.7">
            <animate attributeName="r" values="6;12;6" dur="2.5s" repeatCount="indefinite" />
            <animate attributeName="opacity" values="0.7;0.2;0.7" dur="2.5s" repeatCount="indefinite" />
          </circle>
          <!-- Routing lines -->
          <path class="eco-route" d="M160 106 L60 80" />
          <path class="eco-route" d="M160 106 L260 80" />
          <path class="eco-route" d="M160 214 L60 240" />
          <path class="eco-route" d="M160 214 L260 240" />
          <!-- Ambient orbital activity -->
          <circle cx="160" cy="50" r="4" fill="#7f9fff" opacity="0.18">
            <animateMotion dur="8s" repeatCount="indefinite" path="M160,50 A110,54 0 1,1 159.9,50" />
          </circle>
          <circle cx="160" cy="270" r="4" fill="#7f9fff" opacity="0.18">
            <animateMotion dur="8s" repeatCount="indefinite" path="M160,270 A110,54 0 1,0 160.1,270" />
          </circle>
          <!-- Glow -->
          <circle cx="160" cy="160" r="120" fill="url(#ecoGlow)" filter="url(#ecoBlur)" />
        </svg>
        <div class="eco-glow"></div>
      </div>
    </div>
  </section>


