        <PartnerCard Name="Cloudflare" Icon="/assets/partners/cloudflare.svg" Mark="CF" Badges="DNS,Edge,Routing" Detail="DNS, edge delivery, Pages, Workers, routing, and public web infrastructure." />
        <PartnerCard Name="Cloudflare Workers" Icon="/assets/partners/cloudflare-workers.svg" Mark="CW" Badges="Serverless,Edge,Gateway" Detail="Serverless edge runtime for gateway delivery, routing, and public deployment surfaces." />
    </PartnerSection>

    <PartnerSection Title="Development Systems">
