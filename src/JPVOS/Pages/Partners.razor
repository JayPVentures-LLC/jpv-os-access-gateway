@page "/partners"

<PageTitle>JPV-OS Partners</PageTitle>

<section class="hero-shell compact">
    <div class="eyebrow">PARTNER LAYER</div>
    <h1>Built with an ecosystem<br />of trusted platforms.</h1>
    <p class="hero-copy">
        JPV-OS is assembled through a disciplined operating stack across identity, cloud, development,
        payments, access, communications, creative tooling, research, deployment, and operational infrastructure.
    </p>

    <div class="hero-actions">
        <NavLink class="primary-btn" href="/init">Access Init</NavLink>
        <NavLink class="ghost-btn" href="/access-routing">Route Request</NavLink>
    </div>
</section>

<section class="partner-grid">
    @foreach (var partner in PartnerItems)
    {
        <article class="partner-card">
            <img class="partner-logo" src="@partner.Icon" alt="@partner.Name logo" loading="lazy" />
            <span>@partner.Layer</span>
            <h2>@partner.Name</h2>
            <p>@partner.Role</p>
        </article>
    }
</section>

