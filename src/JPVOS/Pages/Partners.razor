@page "/partners"

<section class="jpv-section partners-hero">
    <div class="jpv-kicker">Trusted Operating Stack</div>
    <h1 class="jpv-title">Built with an ecosystem of trusted platforms.</h1>
    <p class="jpv-lede">
        JPV-OS is an operating ecosystem map for infrastructure, identity, deployment,
        intelligence, creator operations, education, and workstation execution.
    </p>

    <PartnerSection Title="Enterprise Infrastructure">
        <PartnerCard Name="Microsoft" Icon="/assets/partners/microsoft.svg" Mark="MS" Badges="Enterprise,Operations,Platform" Detail="Productivity, Windows operations, identity-adjacent infrastructure, and organizational systems." />
        <PartnerCard Name="Windows" Icon="/assets/partners/windows.svg" Mark="WIN" Badges="Workstation,OS,Execution" Detail="Desktop operating environment for development, administration, automation, and enterprise execution." />
        <PartnerCard Name="Google Workspace" Icon="/assets/partners/google-workspace.svg" Mark="GW" Badges="Email,Calendar,Docs" Detail="Email, calendar, documents, collaboration, and operational coordination." />
        <PartnerCard Name="IBM" Icon="/assets/partners/ibm.svg" Mark="IBM" Badges="Enterprise,Systems,Institutional" Detail="Enterprise systems lineage, infrastructure thinking, and institutional technology influence." />
        <PartnerCard Name="Verizon" Icon="/assets/partners/verizon.svg" Mark="VZ" Badges="Network,Connectivity,Comms" Detail="Connectivity, communications infrastructure, and network ecosystem relevance." />
    </PartnerSection>

    <PartnerSection Title="Identity & Security">
        <PartnerCard Name="Microsoft Entra ID" Icon="/assets/partners/entra-id.svg" Mark="ME" Badges="Identity,MFA,Conditional Access" Detail="Authentication, MFA, conditional access, and secure identity architecture." />
        <PartnerCard Name="Microsoft Security" Icon="/assets/partners/microsoft-security.svg" Mark="SEC" Badges="Security,Risk,Admin" Detail="Security posture, account protection, admin safeguards, and organizational risk reduction." />
