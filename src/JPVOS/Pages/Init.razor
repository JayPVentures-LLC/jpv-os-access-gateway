@page "/init"

<section class="init-hero">
    <div class="eyebrow">APPLICATION LAYER</div>
    <div class="init-lockup">
        <img src="@AssetPaths.Init.Hero" alt="init logo" />
        <div>
            <h1>init</h1>
            <p>Unified ecosystem interface for routing requests into the correct JPV-OS layer.</p>
        </div>
    </div>

    <div class="hero-actions">
        <NavLink class="primary-btn" href="/access-routing">Start Routing</NavLink>
        <NavLink class="ghost-btn" href="/partners">View Partner Layer</NavLink>
    </div>
</section>

<section class="status-panel">
    <div><span>SYSTEM STATUS</span><strong>OPERATIONAL</strong></div>
    <div><span>GATEWAY</span><strong>READY</strong></div>
    <div><span>STANDARD</span><strong>JPV-OS</strong></div>
</section>

<section class="route-stack">
    <div class="glass-card">
        <span>ONE INTERFACE</span>
        <h2>Every request enters through a structured gateway.</h2>
        <p>init keeps routing clear across enterprise, research, innovation, creator, partner, operations, and security paths.</p>
    </div>
</section>


